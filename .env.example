# Copy this file to `.env` and fill in the token.
# `.env` is gitignored and must NEVER be committed.
#
# Generate the token at:
#   GitHub -> Settings -> Developer settings -> Personal access tokens -> Fine-grained tokens
# Scope it to:
#   Repository access: Only select repositories -> flyout-lite
#   Permissions:       Contents = Read and write, Metadata = Read-only
# Expiration: keep it short (7-30 days). Regenerate when needed.

GITHUB_TOKEN=github_pat_PLACEHOLDER
GITHUB_USERNAME=AhmedCemil
GITHUB_REPO=flyout-lite
